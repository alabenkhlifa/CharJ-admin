# Google Maps JavaScript API key.
# Same key as the mobile app's GOOGLE_MAPS_API_KEY in charj/.env.
# Vite inlines VITE_* env vars into the JS bundle at build time.
# Restrict by HTTP referrer in GCP console — do not assume secrecy.
VITE_GOOGLE_MAPS_API_KEY=

# Supabase — same project as the mobile app
# (EXPO_PUBLIC_SUPABASE_URL / EXPO_PUBLIC_SUPABASE_ANON_KEY in charj/.env).
# The anon key is public by design; RLS controls what it can read.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Login gate (security theater — bundle is public, password is visible
# to anyone who reads the JS). Acceptable for keeping casual / drive-by
# traffic off an internal tool. Replace with Supabase Auth before
# putting any sensitive data on this page.
# Leave both empty to disable the gate (e.g. local dev).
VITE_ADMIN_USER=
VITE_ADMIN_PASS=

# Shared secret for admin Edge Functions (e.g. /functions/v1/admin-users).
# Same trust model as the gate — anyone who reads the bundle gets it.
# Must match ADMIN_API_SECRET set in Supabase via:
#   npx supabase secrets set ADMIN_API_SECRET=<value>
VITE_ADMIN_API_SECRET=
